# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
PUBLIC_FILE_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,https://elevenorbits.com,https://www.elevenorbits.com
INTERNAL_CRON_SECRET=replace_me
# Production only, when frontend and API are on subdomains of the same root.
# Use .elevenorbits.com so the agent session cookie is visible to both
# elevenorbits.com and api.elevenorbits.com.
SESSION_COOKIE_DOMAIN=

# Database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Admin staff auth
JWT_SECRET=replace_me
ADMIN_BOOTSTRAP_EMAIL=admin@elevenorbits.local
ADMIN_BOOTSTRAP_PASSWORD=replace_me

# Clerk
CLERK_SECRET_KEY=replace_me

# Turnstile
TURNSTILE_SECRET_KEY=replace_me
TURNSTILE_EXPECTED_ACTION=contract_start
TURNSTILE_ALLOWED_HOSTNAMES=elevenorbits.com,www.elevenorbits.com,localhost,127.0.0.1

# Documenso
DOCUMENSO_API_URL=https://app.documenso.com/api/v2
DOCUMENSO_API_TOKEN=replace_me
DOCUMENSO_TEMPLATE_ID=replace_me
DOCUMENSO_TEMPLATE_RECIPIENT_ID=replace_me
DOCUMENSO_WEBHOOK_SECRET=replace_me
DOCUMENSO_AGREEMENT_VERSION=1.0
CONTRACT_SYNC_INTERVAL_MS=300000
CONTRACT_START_RATE_LIMIT_MAX=5
CONTRACT_SYNC_RATE_LIMIT_MAX=15

# Cloudflare R2 private contract/invoice storage
STORAGE_DRIVER=r2
R2_ACCOUNT_ID=1870f1e5b6ac03cafcda908b08725a21
R2_BUCKET_NAME=elevenorbits
R2_BUCKET=elevenorbits
R2_REGION=auto
R2_ENDPOINT=https://1870f1e5b6ac03cafcda908b08725a21.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
# Do not set R2_PUBLIC_BASE_URL for private contract storage.
R2_KEY_PREFIX=

# Stripe
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
STRIPE_CURRENCY=usd
STRIPE_REQUEST_TIMEOUT_MS=20000

# Local storage fallbacks
UPLOAD_DIR=storage/uploads
INVOICE_DIR=storage/invoices

# Email
SUPPORT_EMAIL=support@elevenorbits.com
COMPANY_ADDRESS=3326 Anna Gorge Dr. Valrico, FL 33596
NOTIFICATION_FROM_EMAIL=noreply@elevenorbits.com
NOTIFICATION_FROM_NAME=ElevenOrbits
SMTP_HOST=mail.elevenorbits.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@elevenorbits.com
SMTP_PASSWORD=replace_me
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_TLS_SERVERNAME=server313-3.web-hosting.com
